# 防火墙配置
FW_IP=192.168.1.1
FW_USERNAME=admin
FW_PASSWORD=your_firewall_password

# 邮件配置
MAIL_HOST=smtp.example.com
MAIL_USER=notification@example.com
MAIL_PASSWORD=your_smtp_password
MAIL_SENDER=notification@example.com
MAIL_RECEIVERS=admin@example.com,security@example.com

# 企业微信配置（可选）
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_webhook_key_here

# IP白名单（逗号分隔）
IP_WHITELIST=10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,127.0.0.1

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/hw-fw-pysyslog.log
LOG_MAX_BYTES=52428800
LOG_BACKUP_COUNT=10

# 数据文件路径
ATTACK_FILE=data/Att.txt

# Syslog服务器配置
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=514

# MaxMind GeoIP 配置（可选，用于IP地理位置查询）
MAXMIND_LICENSE_KEY=
MAXMIND_ACCOUNT_ID=
